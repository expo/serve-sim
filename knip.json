{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "tags": [
    "-lintignore"
  ],
  "ignore": [
    "**/__tests__/**",
    "**/*.test.{ts,tsx,js,jsx}"
  ],
  "workspaces": {
    ".": {},
    "packages/serve-sim": {
      "ignoreDependencies": [
        "preact"
      ],
      "entry": [
        "src/index.ts",
        "src/devtools-plugin.ts",
        "src/middleware.ts",
        "src/state.ts",
        "src/client/client.tsx",
        "src/client/global.css",
        "build.ts",
        "scripts/build-trails.ts"
      ]
    },
    "packages/serve-sim-client": {
      "ignoreDependencies": [
        "react-dom",
        "@types/react-dom"
      ]
    }
  }
}
